#!/bin/bash
export TMPDIR=/home/nunix/.sle-kit/temp
mkdir -p $TMPDIR

START_TIME=$(date +%s)

# Check if llama-server is running
if ! curl -s -f http://127.0.0.1:8000/v1/models > /dev/null; then
    echo "Starting llama-server.service..."
    systemctl --user start llama-server.service
    # Wait for it to be ready (HTTP 200)
    while ! curl -s -f http://127.0.0.1:8000/v1/models > /dev/null; do
        sleep 1
    done
fi

if [ $# -eq 0 ]; then
    OPENAI_API_KEY="EMPTY" kit --config ~/.sle-kit/configs/matey.yml --provider-url "http://127.0.0.1:8000/v1" --system-prompt "$(cat ~/.sle-kit/prompts/matey-prompt.md)"
else
    # Fetch context using psql directly
    CONTEXT=$(psql postgresql://nunix:nunix@localhost/ship_state -t -A -c "SELECT '[' || actor || ' - ' || event_type || ']' || chr(10) || CASE WHEN length(content) > 1000 THEN substr(content, 1, 1000) || '...[TRUNCATED]' ELSE content END || chr(10) FROM (SELECT * FROM Timeline ORDER BY timestamp DESC LIMIT 10) sub ORDER BY timestamp ASC;")

    SYS_PROMPT=$(cat ~/.sle-kit/prompts/matey-prompt.md)
    USER_PROMPT="$*"
    
    # Log the prompt
    CLEAN_PROMPT="${USER_PROMPT//\'/\'\'}"
    psql postgresql://nunix:nunix@localhost/ship_state -c "INSERT INTO Timeline (session_id, actor, event_type, content) VALUES ((SELECT session_id FROM ActiveSession WHERE id=1), 'User', 'AI_Prompt', '$CLEAN_PROMPT');"

    INJECTED_PROMPT="$SYS_PROMPT

<timeline_context>
$CONTEXT
</timeline_context>

Based on the timeline context above, please respond to the following prompt. Do not generate transcript tags like [Matey - AI_Response]. Just provide your answer:
$USER_PROMPT"

    # Run and capture output as JSON, then extract the response
    RAW_OUTPUT=$(OPENAI_API_KEY="EMPTY" kit --config ~/.sle-kit/configs/matey.yml --provider-url "http://127.0.0.1:8000/v1" --system-prompt "$(cat ~/.sle-kit/prompts/matey-prompt.md)" --no-session --quiet --json "$INJECTED_PROMPT")
    OUTPUT=$(echo "$RAW_OUTPUT" | jq -r .response)
    
    # Strip ANSI codes just in case
    CLEAN_OUTPUT=$(echo "$OUTPUT" | sed -r 's/\x1B\[[0-9;]*[a-zA-Z]//g')
    CLEAN_OUTPUT_SQL="${CLEAN_OUTPUT//\'/\'\'}"
    
    # Log the response
    psql postgresql://nunix:nunix@localhost/ship_state -c "INSERT INTO Timeline (session_id, actor, event_type, content) VALUES ((SELECT session_id FROM ActiveSession WHERE id=1), 'Matey', 'AI_Response', '$CLEAN_OUTPUT_SQL');"
    
    echo "$OUTPUT"
fi

END_TIME=$(date +%s)
EXEC_TIME=$((END_TIME - START_TIME))
echo "Execution time: ${EXEC_TIME}s" >> /tmp/minihal_time.txt
