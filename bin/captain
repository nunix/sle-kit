#!/bin/bash

if [ $# -eq 0 ]; then
    exec kit --config ~/.sle-kit/configs/captain.yml --system-prompt "$(cat ~/.sle-kit/prompts/captain-prompt.md)"
else
    # Fetch context using psql directly
    CONTEXT=$(psql postgresql://nunix:nunix@localhost/ship_state -t -A -c "SELECT '[' || actor || ' - ' || event_type || ']' || chr(10) || CASE WHEN length(content) > 1000 THEN substr(content, 1, 1000) || '...[TRUNCATED]' ELSE content END || chr(10) FROM (SELECT * FROM Timeline ORDER BY timestamp DESC LIMIT 10) sub ORDER BY timestamp ASC;")
    
    USER_PROMPT="$*"
    
    # Log the prompt
    CLEAN_PROMPT="${USER_PROMPT//\'/\'\'}"
    psql postgresql://nunix:nunix@localhost/ship_state -c "INSERT INTO Timeline (session_id, actor, event_type, content) VALUES ((SELECT session_id FROM ActiveSession WHERE id=1), 'User', 'AI_Prompt', '$CLEAN_PROMPT');"

    INJECTED_PROMPT="<timeline_context>
$CONTEXT
</timeline_context>

Based on the timeline context above, please respond to the following prompt. Do not generate transcript tags like [Captain - AI_Response]. Just provide your answer:
$USER_PROMPT"

    # Run, stream to TTY, and capture
    OUTPUT=$(kit --config ~/.sle-kit/configs/captain.yml --system-prompt "$(cat ~/.sle-kit/prompts/captain-prompt.md)" --no-session "$INJECTED_PROMPT" | tee /dev/tty)
    
    # Strip ANSI codes and progress bar characters
    CLEAN_OUTPUT=$(echo "$OUTPUT" | sed -r 's/\x1B\[[0-9;]*[a-zA-Z]//g' | tr -d '▪')
    CLEAN_OUTPUT_SQL="${CLEAN_OUTPUT//\'/\'\'}"
    
    psql postgresql://nunix:nunix@localhost/ship_state -c "INSERT INTO Timeline (session_id, actor, event_type, content) VALUES ((SELECT session_id FROM ActiveSession WHERE id=1), 'Captain', 'AI_Response', '$CLEAN_OUTPUT_SQL');"
fi
