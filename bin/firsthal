#!/bin/bash
export TMPDIR=/home/nunix/minihal_temp
mkdir -p $TMPDIR

START_TIME=$(date +%s)

# Check if llama-server is running
if ! curl -s -f http://127.0.0.1:8000/v1/models > /dev/null; then
    echo "Starting llama-server.service..."
    systemctl --user start llama-server.service
    # Wait for it to be ready (HTTP 200)
    while ! curl -s -f http://127.0.0.1:8000/v1/models > /dev/null; do
        sleep 1
    done
fi

if [ $# -eq 0 ]; then
    # Interactive mode: use hal-bin (MCP tools available)
    OPENAI_API_KEY="EMPTY" ~/.local/bin/hal-bin --config /home/nunix/.firsthal.yml --provider-url "http://127.0.0.1:8000/v1" --system-prompt /home/nunix/hal_prompts/firstmate-prompt.md
else
    # Single-shot mode: use Bash Injection to avoid multi-step tool calls
    CONTEXT=$(sqlite3 /home/nunix/.hal_memory/timeline.db "SELECT '[' || actor || ' - ' || event_type || ']' || char(10) || CASE WHEN length(content) > 1000 THEN substr(content, 1, 1000) || '...[TRUNCATED]' ELSE content END || char(10) FROM (SELECT * FROM Timeline WHERE session_id = (SELECT session_id FROM ActiveSession WHERE id=1) ORDER BY timestamp DESC LIMIT 10) ORDER BY timestamp ASC;")

    ALERTS=$(sqlite3 /home/nunix/ship_state.db "SELECT * FROM alerts;")
    ACTIONS=$(sqlite3 /home/nunix/ship_state.db "SELECT * FROM action_log ORDER BY timestamp DESC LIMIT 5;")

    SYS_PROMPT=$(cat /home/nunix/hal_prompts/firstmate-prompt.md)
    USER_PROMPT="$*"
    
    CLEAN_PROMPT="${USER_PROMPT//\'/\'\'}"
    sqlite3 /home/nunix/.hal_memory/timeline.db "INSERT INTO Timeline (session_id, actor, event_type, content) VALUES ((SELECT session_id FROM ActiveSession WHERE id=1), 'User', 'AI_Prompt', '$CLEAN_PROMPT');"

    INJECTED_PROMPT="$SYS_PROMPT

<timeline_context>
$CONTEXT
</timeline_context>

<blackboard_state>
ALERTS:
$ALERTS

RECENT ACTIONS:
$ACTIONS
</blackboard_state>

CRITICAL INSTRUCTION FOR THIS SINGLE-SHOT COMMAND:
The blackboard state and timeline context have been injected above. 
You do not have access to tools in this mode.
Just respond directly to the following prompt. Do not generate transcript tags like [Firstmate - AI_Response].

Prompt: $USER_PROMPT"

    # Escape JSON properly
    JSON_PAYLOAD=$(jq -n \
        --arg model "gemma-4-26B-A4B-it-UD-Q4_K_M.gguf" \
        --arg content "$INJECTED_PROMPT" \
        '{model: $model, messages: [{role: "user", content: $content}]}')

    # Run curl
    RAW_OUTPUT=$(curl -s http://localhost:8000/v1/chat/completions -H "Content-Type: application/json" -d "$JSON_PAYLOAD")
    OUTPUT=$(echo "$RAW_OUTPUT" | jq -r .choices[0].message.content)
    
    CLEAN_OUTPUT=$(echo "$OUTPUT" | sed -r 's/\x1B\[[0-9;]*[a-zA-Z]//g')
    CLEAN_OUTPUT_SQL="${CLEAN_OUTPUT//\'/\'\'}"
    
    sqlite3 /home/nunix/.hal_memory/timeline.db "INSERT INTO Timeline (session_id, actor, event_type, content) VALUES ((SELECT session_id FROM ActiveSession WHERE id=1), 'Firstmate', 'AI_Response', '$CLEAN_OUTPUT_SQL');"
    sqlite3 /home/nunix/ship_state.db "INSERT INTO action_log (actor, action, details) VALUES ('Firstmate', 'Answered single-shot prompt', 'Prompt: $CLEAN_PROMPT');"

    echo "$OUTPUT"
fi

END_TIME=$(date +%s)
EXEC_TIME=$((END_TIME - START_TIME))
echo "Execution time: ${EXEC_TIME}s" >> /tmp/firsthal_time.txt
